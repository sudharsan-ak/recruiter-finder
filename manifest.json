{
  "manifest_version": 3,
  "name": "LinkedIn Recruiter Finder",
  "version": "3.0",
  "description": "Click from any LinkedIn job page — auto-finds all recruiters from the company People tab.",
  "permissions": ["activeTab", "scripting", "tabs", "storage", "sidePanel", "contextMenus"],
  "host_permissions": ["https://www.linkedin.com/*", "<all_urls>"],

  "icons": {
    "16":  "icons/icon16.png",
    "32":  "icons/icon32.png",
    "48":  "icons/icon48.png",
    "128": "icons/icon128.png"
  },

  "commands": {
    "_execute_action": {
      "suggested_key": {
        "default": "Alt+R",
        "mac":     "Command+Shift+R"
      },
      "description": "Open LinkedIn Recruiter Finder"
    }
  },

  "action": {
    "default_title": "Find Recruiters",
    "default_icon": {
      "16":  "icons/icon16.png",
      "32":  "icons/icon32.png",
      "48":  "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },

  "side_panel": {
    "default_path": "popup/popup.html"
  },

  "background": {
    "service_worker": "background/background.js",
    "type": "module"
  },

  "content_scripts": [{
    "matches": ["https://www.linkedin.com/*"],
    "js": [
      "aliases.js",
      "content/content-core.js",
      "content/profile/dom-readers.js",
      "content/profile/company-resolver.js",
      "content/profile-content.js",
      "content/jobs-scanner.js"
    ],
    "run_at": "document_idle"
  }]
}
